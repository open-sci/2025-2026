@prefix scl: <https://www.scielo.org/vocabs/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

scl:Agricultural_Sciences a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Agricultural Sciences"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Applied_Social_Sciences a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Applied Social Sciences"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Biological_Science a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Biological Science"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Engineering a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Engineering"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Exact_and_Earth_Sciences a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Exact and Earth Sciences"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Health_Sciences a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Health Sciences"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Human_sciences a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Human sciences"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Linguistics%2C_Letters_and_Arts a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Linguistics, Letters and Arts"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:Psychoanalysis a skos:Concept ;
    skos:inScheme scl:ConceptScheme ;
    skos:note "Concept created for the purpose of this vocabulary"@en ;
    skos:prefLabel "Psychoanalysis"@en ;
    skos:topConceptOf scl:ConceptScheme .

scl:ConceptScheme a skos:ConceptScheme ;
    skos:hasTopConcept scl:Agricultural_Sciences,
        scl:Applied_Social_Sciences,
        scl:Biological_Science,
        scl:Engineering,
        scl:Exact_and_Earth_Sciences,
        scl:Health_Sciences,
        scl:Human_sciences,
        scl:Linguistics%2C_Letters_and_Arts,
        scl:Psychoanalysis ;
    skos:prefLabel "SCL Concept Scheme"@en .

